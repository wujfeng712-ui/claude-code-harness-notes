<mxfile host="next-ai-draw-io" agent="claude-code-harness-notes">
  <diagram id="core-loop" name="核心循环">
    <mxGraphModel dx="800" dy="500" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="320" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="u" value="用户输入" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="110" height="50" as="geometry" />
        </mxCell>
        <mxCell id="m" value="模型决策&#10;call model" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontColor=#7F4F00;" vertex="1" parent="1">
          <mxGeometry x="220" y="105" width="130" height="80" as="geometry" />
        </mxCell>
        <mxCell id="t" value="执行工具&#10;run tools" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontColor=#2D5A2D;" vertex="1" parent="1">
          <mxGeometry x="430" y="120" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="r" value="结果回填&#10;feed results back" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontColor=#1F3D66;" vertex="1" parent="1">
          <mxGeometry x="630" y="120" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="o" value="输出给用户" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontColor=#6B2B28;" vertex="1" parent="1">
          <mxGeometry x="225" y="245" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="u" target="m"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" value="stop_reason = tool_use" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#D79B00;fontColor=#7F4F00;fontSize=10;" edge="1" parent="1" source="m" target="t"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#82B366;" edge="1" parent="1" source="t" target="r"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" value="下一轮 / loop" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#6C8EBF;fontColor=#1F3D66;fontSize=10;" edge="1" parent="1" source="r" target="m"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="700" y="60" /><mxPoint x="285" y="60" /></Array></mxGeometry></mxCell>
        <mxCell id="e5" value="stop_reason = end" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#B85450;fontColor=#6B2B28;fontSize=10;" edge="1" parent="1" source="m" target="o"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
